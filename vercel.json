{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install",
  "buildCommand": "pnpm -w run build:prod && mkdir -p public && cp -r artifacts/forth-architecture/dist/public/. public/",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/app" }
  ],
  "functions": {
    "api/app.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
