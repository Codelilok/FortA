{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/app" }
  ],
  "functions": {
    "api/app.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
